{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "bellman-gui",
  "version": "0.1.0",
  "identifier": "com.davidtgillard.bellman-gui",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Bellman GUI",
        "width": 1280,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "appimage"
    ],
    "createUpdaterArtifacts": true,
    "externalBin": [
      "binaries/bellman"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk0RTY0MDkzRjc0RUY2N0QKUldSOTlrNzNrMERtbEF3Tm05MVdpNE9mQTd4S3BNcWMrR0NGbm1jK1ZGUzBRdUR1NTM5UWg5dUYK",
      "endpoints": [
        "https://github.com/davidtgillard/bellman-gui/releases/download/dev/latest.json"
      ]
    }
  }
}
