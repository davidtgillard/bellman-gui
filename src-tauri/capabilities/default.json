{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-destroy",
    "core:menu:default",
    "core:event:default",
    "opener:default",
    "dialog:default",
    "shell:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/bellman",
          "sidecar": true
        },
        {
          "name": "bellman-path",
          "cmd": "bellman",
          "args": true
        }
      ]
    }
  ]
}
